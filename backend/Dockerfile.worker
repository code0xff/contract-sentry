FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/home/app/.local/bin:/root/.foundry/bin:$PATH"

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential git curl ca-certificates nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Pre-install common Solidity libraries + Claude CLI for AI campaign generation
RUN npm install -g \
      @openzeppelin/contracts \
      @openzeppelin/contracts-upgradeable \
      @anthropic-ai/claude-code \
    && rm -rf /root/.npm

ENV OZ_CONTRACTS_PATH=/usr/local/lib/node_modules/@openzeppelin

# Install Foundry (forge + anvil) via direct binary download
RUN curl -fsSL https://github.com/foundry-rs/foundry/releases/download/nightly/foundry_nightly_linux_amd64.tar.gz \
    -o /tmp/foundry.tar.gz && \
    tar -xzf /tmp/foundry.tar.gz -C /usr/local/bin forge anvil cast && \
    chmod +x /usr/local/bin/forge /usr/local/bin/anvil /usr/local/bin/cast && \
    rm /tmp/foundry.tar.gz

RUN useradd -m -u 1000 app

WORKDIR /app

COPY requirements.txt ./
# Install Python deps + slither (web3 v6 compatible)
RUN pip install --no-cache-dir -r requirements.txt slither-analyzer

# Install mythril in isolated venv to avoid web3 v5/v6 conflict
# mythril requires web3<6; the app requires web3>=6 — they cannot share site-packages
RUN python -m venv /opt/mythril-venv && \
    /opt/mythril-venv/bin/pip install --no-cache-dir mythril && \
    ln -sf /opt/mythril-venv/bin/myth /usr/local/bin/myth

# Echidna (static binary)
RUN apt-get update -qq && apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -L https://github.com/crytic/echidna/releases/download/v2.2.3/echidna-2.2.3-x86_64-linux.tar.gz \
    -o /tmp/echidna.tar.gz && \
    tar -xzf /tmp/echidna.tar.gz -C /usr/local/bin/ && \
    chmod +x /usr/local/bin/echidna && \
    rm /tmp/echidna.tar.gz

# Medusa fuzzer
RUN curl -L https://github.com/crytic/medusa/releases/download/v0.1.8/medusa-linux-x64.tar.gz \
    -o /tmp/medusa.tar.gz && \
    tar -xzf /tmp/medusa.tar.gz -C /usr/local/bin/ && \
    chmod +x /usr/local/bin/medusa && \
    rm /tmp/medusa.tar.gz

COPY app ./app

USER app

CMD ["celery", "-A", "app.workers.celery_app.celery_app", "worker", \
     "-Q", "static_analysis,dynamic_analysis,simulation,report", \
     "--loglevel=info", "--concurrency=2"]
