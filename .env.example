# Backend API
DATABASE_URL=sqlite+aiosqlite:///./contract_centry.db
# For PostgreSQL: postgresql+asyncpg://centry:centry@postgres:5432/centry

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application
ENV=development
LOG_LEVEL=INFO
APP_NAME=contract-centry

# Sandbox limits
SANDBOX_CPU=2
SANDBOX_MEMORY=4g
STATIC_ANALYSIS_TIMEOUT_S=300
DYNAMIC_ANALYSIS_TIMEOUT_S=600
SIMULATION_TIMEOUT_S=900

# Upload limits
MAX_CONTRACT_BYTES=524288

# Analysis tool binaries (override if not on PATH)
SLITHER_BIN=slither
MYTHRIL_BIN=myth
ECHIDNA_BIN=echidna-test
FORGE_BIN=forge
ANVIL_BIN=anvil

# Fork network (optional — required for fork simulation)
FORK_RPC_URL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
